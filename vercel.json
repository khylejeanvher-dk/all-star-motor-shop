{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/product.html", "destination": "/product.html" },
    { "source": "/category.html", "destination": "/category.html" },
    { "source": "/about.html", "destination": "/about.html" },
    { "source": "/contact.html", "destination": "/contact.html" },
    { "source": "/", "destination": "/index.html" }
  ]
}